{
  "name": "bughouse-ladder-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "git:init": "powershell -ExecutionPolicy Bypass -File .\\session-git.ps1",
    "git:commit": "powershell -ExecutionPolicy Bypass -File .\\git-auto.ps1 commit",
    "git:push": "powershell -ExecutionPolicy Bypass -File .\\git-auto.ps1 push",
    "git:full": "powershell -ExecutionPolicy Bypass -File .\\git-auto.ps1 full",
    "test:automation": "node scripts/automation-cli.cjs",
    "test:automation:all": "node scripts/automation-cli.cjs --config test-cases/00-test_all.json",
    "test:automation:watch": "npm run test:automation -- --rebuild"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "lucide-react": "^0.575.0",
    "mime-types": "^3.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sheetjs": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "http-server": "^14.1.1",
    "jsdom": "^28.1.0",
    "mime": "^4.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.0.18"
  }
}
